{
  "name": "agentguard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "agentguard": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "demo": "npm run dev",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-query": "^4.36.0",
    "@trpc/client": "^10.45.0",
    "@trpc/react-query": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "ai": "^6.0.214",
    "commander": "^15.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "gsap": "^3.15.0",
    "headroom-ai": "^0.22.4",
    "mysql2": "^3.11.0",
    "neo4j-driver": "^6.1.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sarvam-ai-sdk": "^0.3.1",
    "sonner": "^1.7.0",
    "wouter": "^3.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
